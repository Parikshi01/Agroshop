# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- Server ---
NODE_ENV=development
PORT=5000

# --- CORS ---
# Comma-separated list of origins allowed to call this API.
# Example for production: https://agroshop.com,https://www.agroshop.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# --- Database ---
# Option A: single connection string (used automatically if set — this is what
# managed hosts like Render, Railway, Neon and Supabase give you)
# DATABASE_URL=postgresql://user:password@host:5432/agroshop_db

# Option B: individual fields (used if DATABASE_URL is not set — for local dev)
PGHOST=localhost
PGPORT=5432
PGDATABASE=agroshop_db
PGUSER=postgres
PGPASSWORD=change_me

# Set to "true" when connecting to a hosted Postgres that requires SSL
# (Render, Railway, Neon, Supabase all require this in production)
PGSSL=false

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
